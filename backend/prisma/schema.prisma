generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoomStatus {
  AVAILABLE
  IN_SERVICE
  PAUSED
  CLOSED
  UNAVAILABLE
}

enum UserRole {
  ADMIN
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(ADMIN)
  auditLogs    AuditLog[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Doctor {
  id        String   @id @default(cuid())
  name      String
  specialty String
  crm       String?
  phone     String?
  email     String?
  photoUrl  String?
  active    Boolean  @default(true)
  rooms     Room[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Room {
  id          String     @id @default(cuid())
  name        String
  description String?
  floor       String?
  status      RoomStatus @default(AVAILABLE)

  doctorId String?
  doctor   Doctor? @relation(fields: [doctorId], references: [id])

  devices Device[]

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Device {
  id          String   @id @default(cuid())
  name        String
  deviceCode  String   @unique
  pairingCode String   @unique

  roomId String?
  room   Room? @relation(fields: [roomId], references: [id])

  isOnline   Boolean   @default(false)
  lastSeenAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
}
